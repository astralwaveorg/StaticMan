# NAME: Proxy
# URL: https://magichub.top/download/clash/rules/proxy.list

# --- 自定义代理域名 ---
DOMAIN-SUFFIX,qichiyu.com
DOMAIN-SUFFIX,v2ex.com

# --- Docker Hub 官方 ---
DOMAIN-SUFFIX,docker.io
DOMAIN-SUFFIX,hub.docker.com
DOMAIN-SUFFIX,auth.docker.io
DOMAIN-SUFFIX,registry-1.docker.io
# 【关键】Docker Hub 的实际镜像数据存储在 Cloudflare CDN
DOMAIN-SUFFIX,production.cloudflare.docker.com

# --- GitHub Container Registry (GHCR) ---
DOMAIN-SUFFIX,ghcr.io
# 【关键】GHCR 的实际镜像数据存储在这里
DOMAIN-SUFFIX,pkg-containers.githubusercontent.com

# --- Google Container Registry (GCR) & Kubernetes ---
DOMAIN-SUFFIX,gcr.io
DOMAIN-SUFFIX,us.gcr.io
DOMAIN-SUFFIX,eu.gcr.io
DOMAIN-SUFFIX,asia.gcr.io
# 旧版 K8s 镜像仓库
DOMAIN-SUFFIX,k8s.gcr.io
# 新版 K8s 镜像仓库 (必须添加，否则新版 K8s 组件无法下载)
DOMAIN-SUFFIX,registry.k8s.io
# 【关键】GCR 的实际数据存储在 Google Cloud Storage
DOMAIN-SUFFIX,storage.googleapis.com

# --- Quay.io (Red Hat) ---
DOMAIN-SUFFIX,quay.io
# Quay 的 CDN 域名
DOMAIN-SUFFIX,cdn.quay.io
DOMAIN-SUFFIX,cdn01.quay.io
DOMAIN-SUFFIX,cdn02.quay.io
DOMAIN-SUFFIX,cdn03.quay.io

# --- Microsoft Container Registry (可选，推荐添加) ---
# VS Code Dev Containers 和 .NET 镜像常用
DOMAIN-SUFFIX,mcr.microsoft.com
