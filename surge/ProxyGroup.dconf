#!MANAGED-CONFIG https://list.magichub.top/d/surge/ProxyGroup.dconf interval=21600 strict=false

[Proxy Group]
🚀 节点选择 = select, "♻️ 自动优选", "🇸🇬 新加坡", "🇯🇵 日本", "🇭🇰 香港", "🇨🇳 台湾", "🇺🇸 美国", "🇺🇸 美国自建01", "🇺🇸 美国自建02", no-alert=0, hidden=0, include-other-group=🥣 代理池, policy-regex-filter=^(?!.*(直连|DIRECT)).*$, include-all-proxies=0
💬 社交通讯 = select, "🇸🇬 新加坡", "🚀 节点选择", "🇨🇳 台湾", "🇯🇵 日本", "🇭🇰 香港", "🇺🇸 美国", no-alert=0, hidden=0, include-all-proxies=0
🌌 Google = select, "🇺🇸 美国", "🇸🇬 新加坡", "🇯🇵 日本", "🚀 节点选择", no-alert=0, hidden=0, include-all-proxies=0
📺 国际媒体 = select, "🇸🇬 新加坡", "🚀 节点选择", "🇯🇵 日本", "🇺🇸 美国", "🇨🇳 台湾", "🇭🇰 香港", no-alert=0, hidden=0, include-all-proxies=0
👨‍💻 开发运维 = select, "🇺🇸 美国", "🇯🇵 日本", "🇸🇬 新加坡", "🚀 节点选择", no-alert=0, hidden=0, include-all-proxies=0
🤖 OpenAI = select, "🇺🇸 美国", "🇯🇵 日本", "🇸🇬 新加坡", "🚀 节点选择", no-alert=0, hidden=0, include-all-proxies=0
🧠 Claude = select, "🇺🇸 美国", "🇯🇵 日本", "🇸🇬 新加坡", "🚀 节点选择", no-alert=0, hidden=0, include-all-proxies=0
🔮 其他 AI = select, "🇸🇬 新加坡", "🇯🇵 日本", "🇺🇸 美国", "🚀 节点选择", no-alert=0, hidden=0, include-all-proxies=0
🐟 漏网之鱼 = select, "♻️ 自动优选", "🚀 节点选择", 自建组, DIRECT, no-alert=0, hidden=0, include-all-proxies=0
🥣 代理池 = smart, include-other-group="线路A, 线路B, 线路C", policy-regex-filter=^(?!.*(流量|客服|到期|有效|时间|直连|DIRECT|越南|重置|动态)).*$, no-alert=0, hidden=1, include-all-proxies=1
♻️ 自动优选 = smart, include-other-group=🥣 代理池, hidden=1, interval=300, tolerance=50, evaluate-before-use=true, no-alert=0, include-all-proxies=1
🇭🇰 香港 = smart, include-other-group=🥣 代理池, hidden=1, policy-regex-filter=(?i)(港|HK|Hong\s*Kong), interval=300, tolerance=50, evaluate-before-use=true
🇯🇵 日本 = smart, include-other-group=🥣 代理池, hidden=1, policy-regex-filter=(?i)(日本|东京|大阪|埼玉|JP|Japan), interval=300, tolerance=50, evaluate-before-use=true
🇺🇸 美国 = smart, "🇺🇸 美国自建01", "🇺🇸 美国自建02", include-other-group="🥣 代理池", hidden=1, policy-regex-filter=(?i)(美国|洛杉矶|圣何塞|西雅图|纽约|芝加哥|波特兰|达拉斯|\bUS\b|United\s*States|America), interval=300, tolerance=50, evaluate-before-use=true, no-alert=0, include-all-proxies=0
🇸🇬 新加坡 = smart, include-other-group=🥣 代理池, hidden=1, policy-regex-filter=(?i)(坡|新加坡|狮城|SG|Singapore), interval=300, tolerance=50, evaluate-before-use=true
🇨🇳 台湾 = smart, include-other-group=🥣 代理池, hidden=1, policy-regex-filter=(?i)(台湾|台北|台中|新北|TW|Taiwan), interval=300, tolerance=50, evaluate-before-use=true
自建组 = smart, "🇺🇸 美国自建01", "🇺🇸 美国自建02", no-alert=0, hidden=1, include-all-proxies=0
线路A = select, policy-path=https://list.magichub.top/d/surge/nodes/DaWang.ini, update-interval=3600, hidden=1, no-alert=0, include-all-proxies=0
线路B = select, policy-path=https://list.magichub.top/d/surge/nodes/lyh.ini, update-interval=3600, hidden=1, no-alert=0, include-all-proxies=0
线路C = select, policy-path=https://list.magichub.top/d/surge/nodes/lyh.ini, update-interval=3600, hidden=1, no-alert=0, include-all-proxies=0
